# === Case 3: Tool Development 環境變數 ===
# 注意：OPENAI_API_KEY 不在此設定，請在前端介面填入

# --- 伺服器 Port（容器對外暴露的 port） ---
BACKEND_PORT=8003
FRONTEND_PORT=3003

# --- 資料庫 ---
DB_PATH=data/inventory.db

# --- CORS ---
CORS_ORIGINS=*

# --- Docker Labels ---
DEVELOPER_NAME=your-name
PROJECT_PATH=case3_tool_development
