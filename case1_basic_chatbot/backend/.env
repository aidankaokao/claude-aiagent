# === Case 1: Basic Chatbot 環境變數 ===

# --- LLM 設定 ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1

# --- 伺服器 Port（容器對外暴露的 port） ---
BACKEND_PORT=8001
FRONTEND_PORT=3001

# --- 資料庫 ---
DB_PATH=data/chatbot.db

# --- CORS ---
CORS_ORIGINS=*

# --- Docker Labels ---
DEVELOPER_NAME=your-name
PROJECT_PATH=case1_basic_chatbot
